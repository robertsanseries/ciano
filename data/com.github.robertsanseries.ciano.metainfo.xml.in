<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2017 Robert San <robertsanseries@gmail.io> -->
<component type="desktop-application">

  <!-- ===================== IDENTIFICATION ===================== -->
  <id>com.github.robertsanseries.ciano</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0+</project_license>
  <translation type="gettext">com.github.robertsanseries.ciano</translation>

  <!-- ===================== PRESENTATION ===================== -->
  <name>Ciano</name>
  <summary>A multimedia file converter</summary>
  <description>
    <p>The easiest way to convert your multimedia files to the most popular formats.</p>
    <p>Characteristics:</p>
    <ul>
      <li>Conversion of multiple files at the same time</li>
      <li>Possibility of changing the output folder</li>
      <li>Notification support</li>
      <li>Close the application at any time with Ctrl + Q</li>
    </ul>
    <p>Supports the conversion of:</p>
    <ul>
      <li>Video - MP4, MPG, AVI, WMV, FLV, MKV, 3GP, MOV, VOB, OGV, WEBM</li>
      <li>Audio - MP3, WMA, OGG, WAV, AAC, FLAC, AIFF, MMF, M4A</li>
      <li>Images - JPG, BMP, PNG, TIF, GIF, TGA</li>
    </ul>
  </description>

  <!-- ===================== DEVELOPER ===================== -->
  <developer id="com.github.robertsanseries">
    <name>Robert San</name>
  </developer>

  <!-- ===================== SCREENSHOTS ===================== -->
  <screenshots>
    <screenshot type="default" environment="pantheon">
      <image>https://raw.githubusercontent.com/robertsanseries/ciano/master/data/assets/images/screenshot.png</image>
    </screenshot>
  </screenshots>

  <!-- ===================== BRANDING ===================== -->
  <branding>
    <color type="primary">#8AE4FF</color>
  </branding>
  <custom>
    <value key="x-appcenter-color-primary">#8AE4FF</value>
    <value key="x-appcenter-color-primary-text">#000000</value>
    <value key="x-appcenter-suggested-price">5</value>
  </custom>

  <!-- ===================== CAPABILITIES ===================== -->
  <provides>
    <binary>com.github.robertsanseries.ciano</binary>
    <id>com.github.robertsanseries.ciano.desktop</id>
  </provides>
  <launchable type="desktop-id">com.github.robertsanseries.ciano.desktop</launchable>

  <recommends>
    <display_length compare="ge">400</display_length>
  </recommends>
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <!-- ===================== URLS ===================== -->
  <url type="homepage">https://robertsanseries.github.io/ciano</url>
  <url type="bugtracker">https://github.com/robertsanseries/ciano/issues</url>
  <url type="help">https://github.com/robertsanseries/ciano/issues</url>
  <url type="contribute">https://github.com/robertsanseries/ciano/contribute</url>
  <url type="translate">https://github.com/robertsanseries/ciano/tree/main/po</url>
  <url type="donation">https://github.com/sponsors/robertsanseries</url>
  <url type="vcs-browser">https://github.com/robertsanseries/ciano</url>

  <!-- ===================== CONTENT RATING ===================== -->
  <content_rating type="oars-1.1" />

  <!-- ===================== RELEASES ===================== -->
