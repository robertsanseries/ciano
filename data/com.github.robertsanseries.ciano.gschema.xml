<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
    <schema id="com.github.robertsanseries.ciano" path="/com/github/robertsanseries/ciano/">
        <key name="window-width" type="i">
            <default>700</default>
            <summary>Window width</summary>
            <description>Stored width of the main window.</description>
        </key>

        <key name="window-height" type="i">
            <default>450</default>
            <summary>Window height</summary>
            <description>Stored height of the main window.</description>
        </key>

        <key name="is-maximized" type="b">
            <default>false</default>
            <summary>Window maximized state</summary>
            <description>True if the window was last closed in a maximized state.</description>
        </key>

        <key name="output-folder" type="s">
            <default>''</default>
            <summary>Select the output folder</summary>
            <description>Select the output folder</description>
        </key>

        <key name="output-source-file-folder" type="b">
            <default>false</default>
            <summary>Output to source file folder</summary>
            <description>Output to source file folder</description>
        </key>

        <key name="shutdown-computer" type="b">
            <default>false</default>
            <summary>Shutdown computer</summary>
            <description>Shutdown computer</description>
        </key> 

        <key name="open-output-folder" type="b">
            <default>false</default>
            <summary>Open output folder</summary>
            <description>Open output folder</description>
        </key> 

        <key name="complete-notify" type="b">
            <default>true</default>
            <summary>Complete notify</summary>
            <description>Complete notify</description>
        </key> 

        <key name="error-notify" type="b">
            <default>true</default>
            <summary>Erro Notify</summary>
            <description>Erro Notify</description>
        </key>

        <key name="theme" type="i">
          <default>0</default>
          <summary>Application color theme</summary>
          <description>Defines which custom theme is used when follow-system-appearance is disabled.</description>
        </key>

        <key name="follow-system-appearance" type="b">
          <default>true</default>
          <summary>Follow system appearance</summary>
          <description>Whether the application should follow the system appearance (light or dark mode) instead of using a custom theme.</description>
        </key>

        <key name="max-simultaneous-conversions" type="i">
            <default>0</default>
            <summary>Max simultaneous conversions</summary>
            <description>Maximum number of simultaneous conversions allowed. Ignored when use-cpu-cores-limit is enabled.</description>
        </key>

        <key name="use-cpu-cores-limit" type="b">
            <default>false</default>
            <summary>Use CPU cores as conversion limit</summary>
            <description>When enabled, the number of CPU cores is used as the maximum simultaneous conversions limit.</description>
        </key>
    </schema>
</schemalist>
